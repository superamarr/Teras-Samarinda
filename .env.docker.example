# Salin ke .env untuk deploy Docker:
# cp .env.docker.example .env

HTTP_PORT=80

DB_HOST=db
DB_PORT=3306
DB_NAME=terassamarinda
DB_USER=root
DB_PASSWORD=ganti_password_kuat

# Frontend domain production (boleh lebih dari satu, pisahkan koma)
CORS_ALLOWED_ORIGINS=https://taufikramadhani.web.id,https://www.taufikramadhani.web.id

SESSION_NAME=tera_admin
SESSION_TIMEOUT=3600
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAMESITE=None
SESSION_PATH=/
SESSION_DOMAIN=taufikramadhani.web.id

# Build arg frontend API base (proxy ke backend via nginx location /api/)
VITE_API_BASE_URL=/api
