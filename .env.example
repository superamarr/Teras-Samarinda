# Salin ke .env di mesin VPS sebelum docker compose up
# cp .env.example .env

# Port HTTP (host)
HTTP_PORT=80

# MySQL — samakan dengan impor database.sql
DB_NAME=terassamarinda
DB_USER=root
DB_PASSWORD=ganti_password_kuat

