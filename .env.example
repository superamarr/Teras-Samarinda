# Salin ke .env: cp .env.example .env
#
# Konfigurasi ini untuk backend PHP non-Docker (VPS/Laragon/native).
# backend/config/connection.php membaca variabel ini lewat getenv().

# MySQL (sesuaikan dengan database server Anda)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=terassamarinda
DB_USER=root
DB_PASSWORD=ganti_password_kuat

# CORS (pisahkan dengan koma untuk banyak origin, tanpa spasi)
# Development boleh "*", production wajib domain spesifik.
# Contoh production:
# CORS_ALLOWED_ORIGINS=https://teras-samarinda.vercel.app,https://www.teras-samarinda.vercel.app
CORS_ALLOWED_ORIGINS=*

# Session cookie (untuk cross-site gunakan None + Secure=true)
SESSION_NAME=tera_admin
SESSION_TIMEOUT=3600
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAMESITE=None
SESSION_PATH=/
SESSION_DOMAIN=

# Optional: bila backend pakai Railway MySQL, isi lewat dashboard Railway.
# MYSQLHOST=
# MYSQLPORT=
# MYSQLDATABASE=
# MYSQLUSER=
# MYSQLPASSWORD=
