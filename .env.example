# Salin ke .env: cp .env.example .env
#
# PHP (backend/config/connection.php) membaca variabel ini lewat getenv().
# File ini juga dimuat otomatis oleh Docker Compose untuk service php/db.
# Di Laragon: isi DB_* di bawah; connection.php memuat .env dari root project.

# Port HTTP (host) — hanya untuk docker compose
HTTP_PORT=80

# MySQL (sama dengan impor database.sql)
# Lokal Laragon: DB_HOST biasanya localhost
# Docker: DB_HOST di .env diabaikan untuk PHP; compose memaksa host "db"
DB_HOST=localhost
DB_PORT=3306
DB_NAME=terassamarinda
DB_USER=root
DB_PASSWORD=ganti_password_kuat

# CORS (pisahkan dengan koma untuk banyak origin)
# Untuk production Vercel:
# CORS_ALLOWED_ORIGINS=https://teras-samarinda.vercel.app,https://www.teras-samarinda.vercel.app
CORS_ALLOWED_ORIGINS=*

# Session cookie (untuk cross-site gunakan None + Secure=true)
SESSION_NAME=tera_admin
SESSION_TIMEOUT=3600
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAMESITE=Lax
SESSION_PATH=/
SESSION_DOMAIN=

# Build frontend: kosongkan agar API & upload sama origin (disarankan di Docker)
# VITE_API_BASE_URL=
